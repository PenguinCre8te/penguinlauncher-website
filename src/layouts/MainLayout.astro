---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "An open-source Minecraft launcher focused on user freedom and free redistributability.",
} = Astro.props;
---

<html
	lang="en"
	class="lg:text-lg text-penguin-text-light dark:text-penguin-text-dark"
>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>
			{title === "Penguin Launcher" ? title : `${title} - Penguin Launcher`}
		</title>
		<link rel="icon" type="image/png" href="/img/favicon.png" />
		<link rel="sitemap" href="/sitemap-index.xml" />
	</head>
	<body
		class="flex flex-col min-h-screen max-w-4xl min-[128rem]:max-w-6xl mx-auto gap-4 sm:pb-4 bg-center bg-cover bg-fixed bg-[rgb(239,239,239)] dark:bg-[rgb(9,10,12)] bg-[url('/img/background/penguin-backgroundLight.svg')] dark:bg-[url('/img/background/penguin-backgroundDark.svg')]"
	>
		<Header />
		<main class="flex-1 flex flex-col gap-4">
			<slot />
		</main>
		<Footer />
	</body>
</html>
