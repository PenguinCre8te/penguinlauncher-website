---
import { Image, Picture } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import ProseCard from "../components/ui/ProseCard.astro";
import LogoCard from "../components/ui/LogoCard.astro";
import DownloadLink from "../components/ui/DownloadLink.astro";
import { SOCIAL_LINKS } from "../data/social.ts";
import { Icon } from "astro-icon/components";
import Card from "../components/ui/Card.astro";

import packInstallLight from "../assets/screenshots/landing/pack-install_light.png";
import packInstallDark from "../assets/screenshots/landing/pack-install_dark.png";
import packUpdateLight from "../assets/screenshots/landing/pack-update_light.png";
import packUpdateDark from "../assets/screenshots/landing/pack-update_dark.png";
import modInstallLight from "../assets/screenshots/landing/mod-install_light.png";
import modInstallDark from "../assets/screenshots/landing/mod-install_dark.png";
import modUpdateLight from "../assets/screenshots/landing/mod-update_light.png";
import modUpdateDark from "../assets/screenshots/landing/mod-update_dark.png";
import instanceSettingsLight from "../assets/screenshots/landing/instance-settings_light.png";
import instanceSettingsDark from "../assets/screenshots/landing/instance-settings_dark.png";
import themesDark from "../assets/screenshots/landing/themes_dark.png";
---

<MainLayout
	title="Home"
	description="An open source Minecraft launcher with the ability to manage multiple instances, accounts and mods. Focused on user freedom and free redistributability."
>
	<HeroSection />
	<ProseCard>
		<h2>Features</h2>

		<h3>Modpack Management</h3>
		<p>
			Penguin Launcher makes it easier to install and launch modpacks, while
			keeping them clean. You no longer need to manually install and update
			modpacks as Penguin Launcher can do this for you.
		</p>
		<div class="mx-auto not-prose grid grid-cols-1 gap-4 sm:grid-cols-2">
			<Picture
				src={packInstallLight}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the modpack installation user-interface"
				pictureAttributes={{
					class: "dark:hidden",
				}}
			/>
			<Picture
				src={packInstallDark}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the modpack installation user-interface"
				pictureAttributes={{
					class: "hidden dark:block",
				}}
			/>
			<Picture
				src={packUpdateLight}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the modpack updating user-interface"
				pictureAttributes={{
					class: "dark:hidden",
				}}
			/>
			<Picture
				src={packUpdateDark}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the modpack updating user-interface"
				pictureAttributes={{
					class: "hidden dark:block",
				}}
			/>
		</div>

		<h3>Mod Management</h3>
		<p>
			Sick of constantly finding and re-adding that one mod you need? Penguin
			Launcher interfaces directly with Modrinth and CurseForge, allowing you to
			update or install individual mods easily.
		</p>
		<div class="mx-auto not-prose grid grid-cols-1 gap-4 sm:grid-cols-2">
			<Picture
				src={modInstallLight}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the mod installation user-interface"
				pictureAttributes={{
					class: "dark:hidden",
				}}
			/>
			<Picture
				src={modInstallDark}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the mod installation user-interface"
				pictureAttributes={{
					class: "hidden dark:block",
				}}
			/>
			<Picture
				src={modUpdateLight}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the mod updating user-interface"
				pictureAttributes={{
					class: "dark:hidden",
				}}
			/>
			<Picture
				src={modUpdateDark}
				formats={["avif", "webp"]}
				alt="Penguin Launcher screenshot showing the mod updating user-interface"
				pictureAttributes={{
					class: "hidden dark:block",
				}}
			/>
		</div>

		<h3>Instance Management</h3>
		<p>
			Penguin Launcher allows you to create and manage multiple instances of
			Minecraft, each with its own settings, mods, and configurations. This
			means you can easily switch between different setups without any issues.
		</p>
		<Picture
			src={instanceSettingsLight}
			formats={["avif", "webp"]}
			alt="Penguin Launcher screenshot showing the instance management user-interface"
			class="mx-auto not-prose"
			pictureAttributes={{
				class: "dark:hidden",
			}}
		/>
		<Picture
			src={instanceSettingsDark}
			formats={["avif", "webp"]}
			alt="Penguin Launcher screenshot showing the instance management user-interface"
			class="mx-auto not-prose"
			pictureAttributes={{
				class: "hidden dark:block",
			}}
		/>

		<h3>Lightweight and Customizable</h3>
		<p>
			You don't need an embedded web browser as a game launcher. Penguin Launcher
			is built with the Qt toolkit, requiring very few system resources to run.
			It also lets you customize the menu and supports custom themes.
		</p>
		<Picture
			src={themesDark}
			formats={["avif", "webp"]}
			alt="Penguin Launcher screenshot showing a themed user-interface"
			class="mx-auto not-prose"
		/>

		<h2>I want that!</h2>
		<p>
			You can install Penguin Launcher on Windows, MacOS, and Linux. See the{" "}
			<DownloadLink>Download page</DownloadLink> for more information. You can also
			find community packages there.
		</p>
	</ProseCard>
	<ProseCard>
		<h2 id="get-involved">Get Involved</h2>
		<div class="flex flex-wrap justify-center items-center gap-4 mb-4">
			{
				SOCIAL_LINKS.map((social) => (
					<a
						href={social.href}
						aria-label={social.label}
						class="text-penguin-text-light dark:text-penguin-text-dark"
						target="_blank"
						rel="noopener noreferrer"
					>
						<Card
							variant="foreground"
							class="size-18 flex justify-center items-center"
						>
							<Icon name={social.icon} size="36" />
						</Card>
					</a>
				))
			}
		</div>
		<p>
			Penguin Launcher is an open-source project and we welcome contributions from
			the community. You can find the source code on <a
				href="https://github.com/penguincre8te/PenguinLauncher">GitHub</a
			>. Join our <a href="https://discord.gg/ArX2nafFz2">Discord server</a> to chat
			with other people. We also have a <a
				href="https://matrix.to/#/#penguinlauncher:matrix.org">Matrix space</a
			> for those who don't use Discord.
		</p>
		<h2>Other Information</h2>
		<p>
			Penguin Launcher is <a href="https://github.com/penguincre8te/PenguinLauncher"
				>open-source</a
			> and licensed under GPL-3.
		</p>
		<p>
			Penguin Launcher's logo and related assets are licensed under CC BY-SA 4.0.
		</p>
		<p>
			This website is powered by <a href="https://astro.build">Astro</a>. The <a
				href="https://github.com/PenguinLauncher/penguinlauncher.org">source code</a
			> is licensed under AGPL-3.
		</p>
	</ProseCard>
</MainLayout>
