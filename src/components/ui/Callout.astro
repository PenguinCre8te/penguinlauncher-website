---
interface Props {
	type?: "info" | "success" | "warn" | "danger";
	class?: string;
}

const { type = "info", class: className = "" } = Astro.props;

const variants = {
	info: "border-penguin-info bg-penguin-info/10",
	success: "border-penguin-success bg-penguin-success/10",
	warn: "border-penguin-warn bg-penguin-warn/10",
	danger: "border-penguin-danger bg-penguin-danger/10",
} as const;
---

<div
	class={`rounded-md border border-l-5 px-6 my-6 ${variants[type]} ${className}`}
>
	<slot />
</div>
